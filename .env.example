# =============================================================================
#  SAPPHIRE PMS — Environment Variables (Production)
#  Copy to .env and fill in real values
# =============================================================================

# Database
DB_PASSWORD=your-secure-password-here-min-16-chars

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-min-32-chars-xxxxxxxxxxxxxxxx
PII_ENCRYPTION_KEY=your-pii-key-min-32-chars-xxxxxxxxxxxxxxx
PII_ENCRYPTION_SALT=sapphire-pii-v1

# URLs
FRONTEND_URL=https://sapphire.example.com
APP_URL=https://api.sapphire.example.com
NEXT_PUBLIC_API_URL=https://api.sapphire.example.com

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MOCK_MODE=false

# Email (https://resend.com)
RESEND_API_KEY=re_...
SMTP_FROM=noreply@sapphire.example.com
SUPPORT_EMAIL=support@sapphire.example.com

# Monitoring (https://sentry.io)
SENTRY_DSN=https://...@sentry.io/...
