{
  "expo": {
    "name": "Sapphire",
    "slug": "sapphire",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sapphire",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E27"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sapphire.hotel",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Utilisez Face ID pour vous connecter rapidement à Sapphire",
        "NSCameraUsageDescription": "L'accès à la caméra est nécessaire pour prendre des photos de preuves",
        "NSPhotoLibraryUsageDescription": "L'accès aux photos est nécessaire pour attacher des images",
        "NSLocationWhenInUseUsageDescription": "Pour vous géolocaliser dans l'hôtel",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.sapphire.hotel",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0E27"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4AF37"
        }
      ],
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "L'accès à la caméra permet de prendre des photos de preuves."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://10.0.2.2:5000",
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
