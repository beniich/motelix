// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- NIVEAUX D'ACCÈS ---
enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum PlanType {
  FREE
  PRO
  ELITE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// --- MODÈLES ---

model Hotel {
  id            String   @id @default(uuid())
  name          String
  plan          PlanType @default(FREE)
  createdAt     DateTime @default(now())
  
  // Relations
  users         User[]
  rooms         Room[]
  wineBottles   WineBottle[]
  parkingSpots  ParkingSpot[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  fullName      String
  role          UserRole @default(STAFF)
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  tasks         Task[]
  createdAt     DateTime @default(now())
}

model Room {
  id            String   @id @default(uuid())
  roomNumber    String
  floor         Int
  status        String   // ex: "Occupied", "Cleaning", "Available"
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  
  // Relation avec le mini-bar
  items         MiniBarItem[]
  tasks         Task[]
}

model MiniBarItem {
  id            String   @id @default(uuid())
  name          String   // ex: "Veuve Clicquot 1/2"
  currentWeight Float    // Poids actuel mesuré par le capteur
  idealWeight   Float    // Poids quand la bouteille est pleine
  threshold     Float    // Seuil pour déclencher l'alerte "Low Stock"
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id])
}

model WineBottle {
  id              String   @id @default(uuid())
  name            String
  vintage         Int
  producer        String
  blockchainHash  String   @unique // Signature cryptographique
  price           Float
  stock           Int
  hotelId         String
  hotel           Hotel    @relation(fields: [hotelId], references: [id])
}

model ParkingSpot {
  id            String   @id @default(uuid())
  spotNumber    String
  status        String   // "Available", "Occupied", "Reserved"
  carPlate      String?
  carModel      String?
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
}

model Task {
  id            String     @id @default(uuid())
  description   String
  priority      String     // "NORMAL", "URGENT", "CRITICAL"
  status        TaskStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  
  staffId       String?
  staff         User?      @relation(fields: [staffId], references: [id])
  
  roomId        String?
  room          Room?      @relation(fields: [roomId], references: [id])
}
