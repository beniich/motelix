# ===== Server =====
NODE_ENV=production
PORT=5000
APP_URL=https://api-staging.sapphire.luxury
MARKETING_URL=https://staging.sapphire.luxury
CORS_ORIGIN=https://staging.sapphire.luxury

# ===== Database (SQLite via Prisma) =====
# En dev : file:./dev.db
# En production sur Render : laisser vide si SQLite, ou mettre URL Postgres
DATABASE_URL=file:./prod.db

# ===== Auth (ISO 27001: 32+ chars min) =====
JWT_SECRET=CHANGE_ME_IN_RENDER_32_CHARS_MINIMUM_PLEASE
JWT_EXPIRES_IN=12h
PII_ENCRYPTION_SALT=CHANGE_ME_IN_RENDER_SALT_V1

# ===== Stripe (TEST mode for staging) =====
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_API_VERSION=2024-11-20.acacia
STRIPE_MOCK_MODE=false

# ===== Email (Resend) =====
RESEND_API_KEY=re_xxx
SMTP_FROM=noreply@sapphire.luxury
SUPPORT_EMAIL=support@sapphire.luxury
SALES_EMAIL=sales@sapphire.luxury

# ===== Sentry (error tracking) =====
SENTRY_DSN=https://xxx@sentry.io/xxx

# ===== Slack Alerts =====
SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ===== Storage (S3-compatible) =====
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_KEY=
STORAGE_SECRET=
STORAGE_PUBLIC_URL=

# ===== Feature Flags =====
CHANNEL_MOCK_MODE=false
